# Example .env file for vtcode
#
# Copy this file to .env and add your actual API keys. This is OPTIONAL — the
# preferred way is to export the variable in your shell (e.g. in ~/.zshrc):
#
#   export OPENROUTER_API_KEY=your_key_here
#
# VT Code auto-discovers any provider whose key is already in your environment
# (shell export or this .env file) on first launch, so you do NOT need to paste
# it again in the setup wizard. Keys you paste in the wizard are stored in your
# OS keyring (not this file) to avoid duplicating secrets per workspace.
#
# VT Code automatically infers the correct environment variable based on your provider setting:
# - provider = "openai" → uses OPENAI_API_KEY
# - provider = "anthropic" → uses ANTHROPIC_API_KEY
# - provider = "gemini" → uses GEMINI_API_KEY
# - provider = "deepseek" → uses DEEPSEEK_API_KEY
# - provider = "evolink" → uses EVOLINK_API_KEY
# - provider = "litellm" → uses LITELLM_API_KEY

# API Keys for different providers
# Gemini API Key (recommended)
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative Gemini API Key (Google API Key format)
# GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key (for using open-source models via OpenRouter)
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# DeepSeek API Key
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Evolink API Key (OpenAI-compatible multi-model gateway, https://direct.evolink.ai/v1)
# EVOLINK_API_KEY=your_evolink_api_key_here
# EVOLINK_BASE_URL=https://direct.evolink.ai/v1  # Optional override

# LiteLLM Proxy API Key (optional — only needed if your proxy requires auth)
# LITELLM_API_KEY=your_litellm_api_key_here
# LITELLM_BASE_URL=http://localhost:4000  # Default LiteLLM proxy address

# Ollama API Key (required for Ollama Cloud, not needed for local)
# OLLAMA_API_KEY=your_ollama_api_key_here
# OLLAMA_BASE_URL=https://ollama.com  # Set this for cloud access

# Optional: Additional configuration
# VTCODE_CONTEXT_TOKEN_LIMIT=8000
# VTCODE_PROMPT_REFINER_STUB=false
# COVERAGE_REPORT_PATH=./coverage/report.json

# Optional: Theme configuration
# VT_THEME=ciapre  # Default theme for distributed releases

# Optional: Command restrictions (for security)
# VTCODE_COMMANDS_DENY_LIST=rm,sudo,dd
# VTCODE_COMMANDS_DENY_REGEX=.*dangerous.*
# VTCODE_COMMANDS_ALLOW_LIST=git,cargo,rustc
